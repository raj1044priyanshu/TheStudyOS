{
  "name": "studyos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && next dev",
    "build": "next build",
    "build:clean": "node -e \"require('fs').rmSync('.next-build',{recursive:true,force:true});require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "node -e \"require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && tsc --noEmit --incremental false",
    "verify:clean": "node -e \"require('fs').rmSync('.next-build',{recursive:true,force:true});require('fs').rmSync('tsconfig.tsbuildinfo',{force:true})\" && NEXT_DIST_DIR=.next-build next build && npm run typecheck"
  },
