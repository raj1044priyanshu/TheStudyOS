    "@upstash/redis": "^1.37.0",
    "@xyflow/react": "^12.10.1",
    "axios": "^1.13.6",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
